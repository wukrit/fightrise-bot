# ===================================
# FightRise Beta Environment Configuration
# ===================================
# Copy this file to .env.beta and fill in your values
# This file is SAFE to commit - .env.beta contains secrets and is gitignored

# ===================================
# Database (PostgreSQL) - from docker-compose.beta.yml
# ===================================
DATABASE_URL="postgresql://fightrise_beta:betapassword@localhost:5433/fightrise_beta"

# ===================================
# Redis - from docker-compose.beta.yml
# ===================================
REDIS_URL="redis://localhost:6380"

# BullMQ worker concurrency (default: 1)
BULLMQ_CONCURRENCY=1

# ===================================
# Discord Beta Bot Configuration
# ===================================
# Create a new Discord application at: https://discord.com/developers/applications
# See docs/beta-environment.md for detailed setup instructions

# Bot token (Bot tab → Token → Reset Token)
# CRITICAL: Never commit this to version control
DISCORD_TOKEN=""

# Application ID (General Information → Application ID)
DISCORD_CLIENT_ID=""

# OAuth2 Client Secret (OAuth2 → General → Client Secret)
DISCORD_CLIENT_SECRET=""

# ===================================
# Start.gg API Configuration
# ===================================
# Can reuse production Start.gg API key for beta testing
# Get from: https://start.gg/admin/profile/developer
STARTGG_API_KEY=""

# ===================================
# NextAuth Configuration
# ===================================
# Beta web portal URL
NEXTAUTH_URL="http://localhost:4001"

# Secret for encrypting sessions (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=""

# ===================================
# OAuth Redirect URIs
# ===================================
# These must be registered in your Discord/Start.gg application settings
# For beta, use localhost ports since beta runs locally

# Discord OAuth callback
DISCORD_REDIRECT_URI="http://localhost:4001/api/auth/callback/discord"

# Discord bot installation callback
DISCORD_BOT_REDIRECT_URI="http://localhost:4001/api/auth/callback/bot"

# Start.gg OAuth callback
STARTGG_REDIRECT_URI="http://localhost:4001/api/auth/callback/startgg"

# ===================================
# Beta Environment Indicator
# ===================================
NODE_ENV="beta"
