# FightRise Local Development Secrets
# Copy this file to .dmno.env.local and fill in your values
# This file is gitignored - DO NOT commit secrets

# ===================================
# Discord Bot (required)
# ===================================
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_SECRET=your_discord_client_secret

# ===================================
# Start.gg API (required)
# ===================================
STARTGG_API_KEY=your_startgg_api_key

# ===================================
# NextAuth (required)
# ===================================
NEXTAUTH_SECRET=your_nextauth_secret_generate_with_openssl_rand_base64_32

# ===================================
# Smoke Test Credentials (optional)
# ===================================
# Only needed for running smoke tests against real APIs
SMOKE_DISCORD_TOKEN=
SMOKE_DISCORD_CLIENT_SECRET=
SMOKE_STARTGG_API_KEY=
